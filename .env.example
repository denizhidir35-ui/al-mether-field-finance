NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side Google Maps JavaScript API configuration.
# Restart Next.js (or redeploy Vercel) after changing NEXT_PUBLIC_ values.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional production Map ID. DEMO_MAP_ID is used locally when omitted.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Server-only: map each active Company Platform profile email to its Hostinger mailbox password.
# Never prefix this variable with NEXT_PUBLIC_.
HOSTINGER_MAIL_ACCOUNTS_JSON={"denizhidir@almether.com":"","aytacturkbay@almether.com":""}
